# Built artifacts
**/build/
*.apk
*.aar
*.aab
*.ap_

# Firebase — download from Firebase console per app; never commit production secrets in a public fork
app/google-services.json

# Release signing — NEVER commit the keystore or its passwords (only the .template is tracked)
keystore.properties
*.jks
*.keystore

# Personal local-only notes (signing playbook, passwords reminders, etc.) — never commit
local/

# Files generated by Gradle
.gradle
/local.properties
/gradle/wrapper/gradle-wrapper.jar

# Kotlin build-session data (Kotlin Gradle plugin 2.x)
.kotlin/

# IDE specific files
.idea/
*.iml
.DS_Store

# Temporary files
*.tmp
*.log

# E2E loop source video — local test asset, never commit (see .claude/commands/e2e-fold-loop.md)
google-pro-fold-video.mp4
