<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Video-only capture — no microphone; exported loops are silent. -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- OpenLoop is privacy-first (ANDROID_STANDARDS §8): no ads, no ad-ID-based analytics.
         firebase-analytics (play-services-measurement) merges the AD_ID permission into the
         manifest automatically; strip it so the artifact matches the Play Console declaration
         "does not use advertising ID". Crashlytics is unaffected (it keys off the Firebase
         installation ID, not the ad ID), and Analytics events still work without it — ad-ID
         *collection* is additionally disabled via the google_analytics_adid_collection_enabled
         meta-data below. https://developer.android.com/training/articles/ad-id -->
    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove" />

    <!-- Loopifying export — WorkManager long-running worker + mediaProcessing FGS (Issue #40). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROCESSING" />
    <!-- API 33+ runtime — progress notification while the user is in another app. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Declare camera hardware usage -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <application
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:resizeableActivity="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenLoop.Starting">

        <!-- Disable Analytics advertising-ID collection (privacy-first; pairs with the AD_ID
             permission removal above). Events/screen tracking keep working without it.
             https://firebase.google.com/docs/analytics/android/configure-data-collection -->
        <meta-data
            android:name="google_analytics_adid_collection_enabled"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.OpenLoop.Starting"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboard|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Shares persisted clips (filesDir/videos/) as content:// URIs via the system share sheet
             (slice 06). exported=false + grantUriPermissions=true means only the temporary, per-share
             FLAG_GRANT_READ_URI_PERMISSION grant lets a receiver read the file; scratch/cache paths
             are not reachable — see res/xml/file_paths. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Android Photo Picker backport for API 26–29 (slice 07). On API 33+ the picker is native
             and on 30–32 it's a system module; on 26–29 this <service> lets Google Play services
             provide the proper picker UI. Without it the framework still resolves to an
             ACTION_OPEN_DOCUMENT fallback, so it degrades gracefully. This is Google's documented
             backport snippet (see the link below), copied verbatim.

             EXPECTED IDE noise (working as intended): Android Studio's code inspector resolves the
             android:name as a class reference and reports 4 "unresolved package" ERRORs
             (android / gms / metadata / ModuleDependencies) because the GMS class is NOT on our
             compile classpath — it's provided at RUNTIME by Google Play services. This is harmless:
             the build, Lint, and runtime are all unaffected. tools:ignore="MissingClass" silences
             only Lint's MissingClass check, not the IDE inspector (a separate engine), and there is
             no clean per-line manifest suppression for it — so those red markers are accepted, not a
             defect. Do NOT remove the <service> to clear them: it is what gives API 26–29 the picker.
             See https://developer.android.com/training/data-storage/shared/photopicker -->
        <!-- WorkManager's merged foreground service — typed for media export (Issue #40).
             https://developer.android.com/develop/background-work/background-tasks/persistent/how-to/long-running -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="mediaProcessing"
            tools:node="merge" />

        <service
            android:name="com.google.android.gms.metadata.ModuleDependencies"
            android:enabled="false"
            android:exported="false"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="com.google.android.gms.metadata.MODULE_DEPENDENCIES" />
            </intent-filter>
            <meta-data android:name="photopicker_activity:0:required" android:value="" />
        </service>
    </application>

</manifest>
